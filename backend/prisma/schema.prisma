generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id             String   @id @default(uuid())
  tenantId       String?  @map("tenant_id")
  name           String
  company        String
  address        String
  stage          String   @default("Needs Estimate")
  roofAgeYears   Int      @map("roof_age_years")
  roofMaterial   String   @map("roof_material")
  lastInspection DateTime @map("last_inspection") @db.Date
  distressFlag   Boolean  @default(false) @map("distress_flag")
  distressReason String?  @map("distress_reason")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("leads")
}

model PropertyLookupCache {
  id               String   @id @default(uuid())
  queryAddress     String   @unique @map("query_address")
  formattedAddress String   @map("formatted_address")
  county           String?
  state            String?
  lat              Float
  lon              Float
  placeType        String   @map("place_type")
  fetchedAt        DateTime @default(now()) @map("fetched_at")

  @@map("property_lookup_cache")
}
